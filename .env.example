# ============================================
# Prompt Polisher — Environment Variables
# ============================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to git!
# ============================================

# ---- Database (PostgreSQL) ----
DATABASE_URL=postgresql+asyncpg://promptpolisher:your_password_here@localhost:5432/prompt_polisher
POSTGRES_USER=promptpolisher
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=prompt_polisher

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0

# ---- Qdrant (Vector Database) ----
QDRANT_URL=http://localhost:6333

# ---- JWT Authentication ----
JWT_SECRET=change-this-to-a-random-64-char-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- OAuth (Google) ----
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/google/callback

# ---- OAuth (GitHub) ----
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/auth/oauth/github/callback

# ---- AI Model ----
MODEL_PATH=./ai/model/checkpoints/latest
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
MODEL_DEVICE=cpu
MAX_NEW_TOKENS=512

# ---- Celery ----
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ---- Frontend ----
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8001

# ---- Misc ----
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000
